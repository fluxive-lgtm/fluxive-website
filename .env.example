# Site Configuration
#NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Add your production URL when deploying:
NEXT_PUBLIC_SITE_URL=https://fluxive.com

# n8n Chat Widget Configuration
# For static hosting (EasyHost, Netlify, Vercel static): Use NEXT_PUBLIC_N8N_WEBHOOK_URL
# For server hosting (Node.js, Vercel serverless): Use N8N_WEBHOOK_URL (more secure)

# Static hosting - exposed to client (use this for EasyHost)
NEXT_PUBLIC_N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/your-webhook-id

# Server-side only - not exposed to client (for Node.js deployments)
# N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/your-webhook-id
